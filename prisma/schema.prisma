generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String?
  role      Role      @default(FREELANCER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
  services  Service[]
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  budget      Float
  category    String
  status      Status   @default(OPEN)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

enum Role {
  FREELANCER
  EMPRESA
}

enum Status {
  OPEN
  IN_PROGRESS
  CLOSED
}